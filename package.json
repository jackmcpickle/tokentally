{
    "name": "tokentally",
    "version": "0.2.3",
    "private": true,
    "description": "Public token leaderboard for AI builders — a single Hono worker on Cloudflare + D1.",
    "type": "module",
    "scripts": {
        "build": "pnpm build:css && pnpm build:reporter",
        "build:css": "tailwindcss -i src/styles/tailwind.css -o src/styles/app.css --minify",
        "build:css:watch": "tailwindcss -i src/styles/tailwind.css -o src/styles/app.css --watch",
        "build:reporter": "pnpm --filter tokenmaxer build",
        "brand:assets": "node scripts/gen-brand-assets.mjs",
        "dev": "pnpm build && wrangler dev",
        "deploy": "pnpm build && wrangler deploy --minify",
        "deploy:preview": "pnpm build && wrangler versions upload --minify",
        "prepare": "pnpm build",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit && tsc -p reporter/tsconfig.json --noEmit",
        "lint": "oxlint",
        "fmt": "oxfmt .",
        "fmt:check": "oxfmt --check .",
        "check": "pnpm lint && pnpm fmt:check && pnpm typecheck && pnpm test",
        "db:migrate:local": "wrangler d1 migrations apply tokentally --local",
        "db:migrate": "wrangler d1 migrations apply tokentally --remote",
        "release": "commit-and-tag-version"
    },
    "dependencies": {
        "@cf-wasm/resvg": "0.3.5",
        "hono": "^4.6.16"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20250109.0",
        "@tailwindcss/cli": "^4.3.3",
        "@types/node": "^26.1.1",
        "commit-and-tag-version": "^13.0.0",
        "esbuild": "^0.28.1",
        "oxfmt": "^0.59.0",
        "oxlint": "^1.74.0",
        "sharp": "^0.35.3",
        "tailwindcss": "^4.3.3",
        "typescript": "^5.7.3",
        "vitest": "^3.2.7",
        "wrangler": "^3.99.0"
    },
    "engines": {
        "node": ">=24"
    },
    "packageManager": "pnpm@11.13.1",
    "commit-and-tag-version": {
        "bumpFiles": [
            {
                "filename": "package.json",
                "type": "json"
            },
            {
                "filename": "reporter/package.json",
                "type": "json"
            }
        ],
        "packageFiles": [
            {
                "filename": "package.json",
                "type": "json"
            }
        ],
        "releaseCommitMessageFormat": "chore(release): {{currentTag}} [skip ci]"
    }
}
